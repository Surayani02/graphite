{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "paths": {
      "@graphite/engine": ["../../packages/engine/pkg/graphite_engine.d.ts"],
      "@graphite/protocol": ["../../packages/protocol/src/index.ts"],
      "@graphite/ui-core": ["../../packages/ui-core/src/index.ts"],
      "@graphite/crdt": ["../../packages/crdt/src/index.ts"],
      "@graphite/plugin-api": ["../../packages/plugin-api/src/index.ts"]
    }
  },
  // gpu-constants.d.ts must be a root file HERE too, not only in
  // tsconfig.worker.json: unit tests import worker modules (e.g.
  // render-damage.test.ts → gpu/render → gpu/buffers), and TypeScript
  // typechecks imported files even when they match `exclude` — but it
  // does NOT load ambient declarations from excluded files. `files`
  // entries are unconditional roots that `exclude` cannot filter, so the
  // WebGPU constant-namespace ambients exist wherever the worker sources
  // get pulled in. (Phase 7 M3)
  "files": ["src/workers/gpu-constants.d.ts"],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/workers/**/*"]
}
