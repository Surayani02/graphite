{
  "name": "@graphite/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Graphite browser application.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.worker.json",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src",
    "clean": "rimraf dist",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@graphite/engine": "workspace:*",
    "@graphite/protocol": "workspace:*",
    "@graphite/ui-core": "workspace:*",
    "@tanstack/react-router": "1.170.17",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.3.2",
    "vite": "^8.1.0",
    "@vitest/coverage-v8": "4.1.9",
    "vitest": "^4.1.9"
  }
