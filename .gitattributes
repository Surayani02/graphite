# Normalize all text files to LF
* text=auto eol=lf

*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.toml  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.rs    text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.lock  text eol=lf -diff

# Binary — never modify
*.wasm  binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.ico   binary
*.ttf   binary
*.woff  binary
*.woff2 binary